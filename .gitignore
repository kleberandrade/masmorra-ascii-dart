# Repositório do livro + código Dart. Para .gitignore Flutter no site, ver o repo masmorra-ascii.

# Python
.venv/
__pycache__/
*.py[cod]
.Python
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Dart (pacotes em code/)
**/.dart_tool/
**/build/

# Sistema operativo
.DS_Store
Thumbs.db
*~

# Editores / IDE (local)
*.swp
*.swo
.cursor/
.idea/
*.iml

# LaTeX / XeLaTeX (ficheiros intermédios fora de output/)
*.aux
*.log
*.out
*.toc
*.fdb_latexmk
*.fls
*.synctex.gz
*.xdv

# Ambiente
.env
.env.local

# Outros
docs/

# output/: versionar apenas EPUB e PDF finais (ignorar DOCX, scripts, etc.)
output/*
!output/masmorra-ascii-dart.epub
!output/masmorra-ascii-dart.pdf